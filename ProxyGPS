-- ================= COMMAND =================
AddHook("OnSendPacket", "cmd", function(type, packet)
    if type == 2 then
        -- /mgl
        local mgl = packet:match("/mgl%s+(%d+)")
        if mgl then
            drop_mgl(mgl)
            talkBubble("`cDropped `w"..mgl.." `8MGL")
            return true
        end
        -- /bgl
        local bgl = packet:match("/bgl%s+(%d+)")
        if bgl then
            drop_bgl(bgl)
            talkBubble("`cDropped `w"..bgl.." `eBGL")
            return true
        end
        -- /dl
        local dl = packet:match("/dl%s+(%d+)")
        if dl then
            drop_dl(dl)
            talkBubble("`cDropped `w"..dl.." `cDL")
            return true
        end
        -- /wl
        local wl = packet:match("/wl%s+(%d+)")
        if wl then
            drop_wl(wl)
            talkBubble("`cDropped `w"..wl.." `9WL")
            return true
        end
        -- /logs
        if packet:find("/logs") then
            showLogs()
            return true
        end
        -- /spinlogs
        if packet:find("/spinlogs") then
            showSpinLogs()
            return true
        end
        -- /chatlogs
        if packet:find("/chatlogs") then
            showChatLogs()
            return true
        end
        -- /fly
        if packet:find("/fly") then
            fly = not fly
            ChangeValue("[C] Modfly", fly)
            talkBubble(fly and "`eModfly: `2ON" or "`eModfly: `4OFF")
            return true
        end
        -- /real
        if packet:find("/real") then
            fw = not fw
            ChangeValue("[M] Fast wheel", fw)
            ChangeValue("[M] Show bubble identity", fw)
            talkBubble(fw and "`eFast Wheel: `2ON" or "`eFast Wheel: `4OFF")
            return true
        end
        -- /tp
        if packet:find("/tp") then
            tp = not tp
            ChangeValue("[M] Pathfinder", tp)
            talkBubble(tp and "`ePath Finder: `2ON" or "`ePath Finder: `4OFF")
            return true
        end
        -- /reme
        if packet:find("/reme") then
            remeh = not remeh
            talkBubble(remeh and "`2Reme: `2ON" or "`2Reme: `4OFF")
            addLog("`2Reme mode " .. (remeh and "`2ON" or "`4OFF"))
            return true
        end
        -- /qeme
        if packet:find("/qeme") then
            qemeh = not qemeh
            talkBubble(qemeh and "`9Qeme: `2ON" or "`9Qeme: `4OFF")
            addLog("`9Qeme mode " .. (qemeh and "`2ON" or "`4OFF"))
            return true
        end
    end
end)

-- ================= SPIN DETECT + FAST SPIN =================
AddHook("OnVariant", "spin_hook", function(var, netid, delay)
    local text = var[2]

    -- Fast Spin (Reme / Qeme)
    if var[0] == "OnTalkBubble" and text and text:find("spun the wheel and got") and
       (text:find("`4(%d+)``!") or text:find("`b(%d+)``!") or text:find("`2(%d+)``!")) then

        local SpunNumber = tonumber(
            text:match("`4(%d+)``!") or
            text:match("`b(%d+)``!") or
            text:match("`2(%d+)``!")
        )
        local Num1, Num2 = SpunNumber // 10, SpunNumber % 10

        local Reme = Num1 + Num2
        if Reme > 10 then Reme = Reme % 10
        elseif Reme == 10 then Reme = 0 end

        local Qeme = Num2
        if Num1 + Num2 == 0 then Qeme = 1 end

        -- Log spin
        --addSpinLog("`eSpun `w"..SpunNumber.." `w| Reme: `^"..Reme.." `w| Qeme: `9"..Qeme)

        local suffix = ""
        if remeh and qemeh then
            suffix = " `w `^REME `w"..Reme.." `9QEME `w"..Qeme..""
        elseif remeh then
            suffix = " `w `^REME `w"..Reme.." "
        elseif qemeh then
            suffix = " `9QEME `w"..Qeme.." "
        end

        if suffix ~= "" then
            SendVariantList({
                [0] = "OnTalkBubble",
                [1] = var[1],
                [2] = "`w[`2REAL`w] ``" .. text .. suffix,
                [3] = var[3]
            })
            return true
        end
    end

    -- Collect & Console detect
    if var[0] == "OnConsoleMessage" then
        local msg = var[1]
        if msg and msg:lower():find("collected") and msg:lower():find("blue gem lock") then
            local count = msg:match("(%d+)")
            if count then
                addLog("`1"..GetLocal().name.." Collected `w"..count.." `eBGL")
                talkBubble("`9Collected `w"..count.." `eBGL")
            end
        end
        if msg and msg:lower():find("collected") and msg:lower():find("mighty garuda lock") then
            local count = msg:match("(%d+)")
            if count then
                addLog("`1"..GetLocal().name.." Collected `w"..count.." `8MGL")
                talkBubble("`9Collected `w"..count.." `8MGL")
            end
        end
        if msg and msg:lower():find("collected") and msg:lower():find("diamond lock") then
            local count = msg:match("(%d+)")
            if count then
                addLog("`1"..GetLocal().name.." Collected `w"..count.." `cDL")
                talkBubble("`9Collected `w"..count.." `cDL")
            end
        end
        if msg and msg:lower():find("collected") and msg:lower():find("world lock") then
            local count = msg:match("(%d+)")
            if count then
                addLog("`1"..GetLocal().name.." Collected `w"..count.." `9WL")
                talkBubble("`9Collected `w"..count.." `9WL")
            end
        end
        if msg and (
            msg:lower():find("spin") or
            msg:lower():find("wheel") or
            msg:lower():find("prize") or
            msg:lower():find("won") or
            msg:lower():find("reward")
        ) then
            addSpinLog("`w: "..msg)
        end
    end

	-- Chat detect
	if var[0] == "OnTalkBubble" then
	    local bubbleNetid = var[1]
	    local raw = var[2]
	    if not raw or raw == "" then return end
	
	    -- Hanya catat jika format player_chat
	    local chatMsg = raw:match("player_chat=(.+)$")
	    if not chatMsg then return end -- skip jika bukan player_chat
	
	    chatMsg = chatMsg:gsub("^%s+", ""):gsub("%s+$", "")
	    if chatMsg == "" then return end
	
	    local name = "Unknown"
	    local local_ = GetLocal()
	    if local_ and local_.netid == bubbleNetid then
	        name = local_.name
	    else
	        local p = GetPlayer(bubbleNetid)
	        if p and p.name then name = p.name end
	    end
	
	    addChatLog(name, chatMsg)
	end

	if var[0] == "OnDialogRequest" and var[1]:find("Telephone") then
		cbgl()
		return true
	end
end)

