-- ================= TALK BUBBLE =================
function talkBubble(text)
    local localPlayer = GetLocal()
    if not localPlayer then return end
    SendVariantList({
        [0] = "OnTalkBubble",
        [1] = localPlayer.netid,
        [2] = text
    })
end

