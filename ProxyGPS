        local itemInfo = GetItemByIDSafe(packet.value)
        local name = itemInfo and itemInfo.name or "Unknown"
        local x = packet.int_x
        local y = packet.int_y
        addLog("`cItem Drop Detected: `w"..name.." `7at ("..x..", "..y..")")
    end
end)
