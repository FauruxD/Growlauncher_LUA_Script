-- ================= REME/QEME CALCULATE =================
function calcReme(num)
	local n = tonumber(num)
	local d1 = math.floor(n / 10)
	local d2 = n % 10
	local reme = d1 + d2
	if reme > 10 then
		reme = reme % 10
	elseif reme == 10 then
		reme = 0
	end
	return reme
end

function calcQeme(num)
	local n = tonumber(num)
	local d1 = math.floor(n / 10)
	local d2 = n % 10
	local qeme = d2
	if d1 + d2 == 0 then
		qeme = 1
	end
	return qeme
end

-- ================= COMMAND =================
AddHook("OnSendPacket", "cmd", function(type, packet)
	if type == 2 then
		-- /bgl
		local bgl = packet:match("/bgl%s+(%d+)")
		if bgl then
			drop_bgl(bgl)
			talkBubble("`cDropped `9"..bgl.." BGL")
			return true
		end
		-- /dl
		local dl = packet:match("/dl%s+(%d+)")
		if dl then
			drop_dl(dl)
			talkBubble("`cDropped `9"..dl.." DL")
			return true
		end
		-- /logs
		if packet:find("/logs") then
			showLogs()
			return true
		end
		-- /spinlogs
		if packet:find("/spinlogs") then
			showSpinLogs()
			return true
		end
		-- /chatlogs
		if packet:find("/chatlogs") then
			showChatLogs()
			return true
		end
		-- /reme
		if packet:find("/reme") then
			remeMode = not remeMode
			if remeMode then
				qemeMode = false
				talkBubble("`4REME Mode `2ON")
			else
				talkBubble("`4REME Mode `8OFF")
			end
			return true
		end
		-- /qeme
		if packet:find("/qeme") then
			qemeMode = not qemeMode
			if qemeMode then
				remeMode = false
				talkBubble("`bQEME Mode `2ON")
			else
				talkBubble("`bQEME Mode `8OFF")
			end
			return true
		end
	end
end)

-- ================= COLLECT DETECT =================
AddHook("OnVariant", "collect", function(var)
	if var[0] == "OnConsoleMessage" then
		local text = var[1]

		-- Collect BGL detect
		if text and text:lower():find("blue gem lock") then
			local count = text:match("(%d+)")
			if count then
				addLog("`1"..GetLocal().name.." Collected `9"..count.." BGL")
				talkBubble("`bCollected `w"..count.."`cBGL")
			end
		end
	end

	-- ================= SPIN + REME/QEME DETECT =================
	if var[0] == "OnTalkBubble" then
		local netid = var[1]
		local raw   = var[2]
		if not raw or raw == "" then return end

		-- Detect spin wheel message
		if raw:find("spun the wheel and got") then
			-- Ambil angka spin dari warna `4, `b, atau `2
			local spinNum = raw:match("`4(%d+)`!") 
				or raw:match("`b(%d+)`!") 
				or raw:match("`2(%d+)`!")

			if spinNum then
				local spinMsg = raw

				-- REME MODE
				if remeMode then
					local reme = calcReme(spinNum)
					spinMsg = spinMsg .. " `4[ Reme : `w" .. reme .. " `4]"
					talkBubble(raw .. " `4[ Reme : `w" .. reme .. " `4]")
					addSpinLog("`w"..spinMsg)
					return true
				end

				-- QEME MODE
				if qemeMode then
					local qeme = calcQeme(spinNum)
					spinMsg = spinMsg .. " `b[ Qeme : `w" .. qeme .. " `b]"
					talkBubble(raw .. " `b[ Qeme : `w" .. qeme .. " `b]")
					addSpinLog("`w"..spinMsg)
					return true
				end

				-- No mode, just log
				addSpinLog("`w"..raw)
			end
		end

		-- ================= CHAT DETECT =================
		-- Parse pesan bersih
		local msg = raw:match("player_chat=(.+)$")
		if not msg then
			msg = raw
		end
		msg = msg:gsub("^%s+", ""):gsub("%s+$", "")

		-- Cari nama player
		local name = "Unknown"
		local local_ = GetLocal()

		if local_ and local_.netid == netid then
			name = local_.name
		else
			local p = GetPlayer(netid)
			if p and p.name then
				name = p.name
			end
		end

		-- Jangan log jika itu pesan spin
		if not raw:find("spun the wheel and got") then
			addChatLog(name, msg)
		end
	end
end)
