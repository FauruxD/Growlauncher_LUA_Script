-- ================= LOG STORAGE =================
logs = {}
spinLogs = {}
chatLogs = {}

-- ================= REME/QEME STATE =================
remeMode = false
qemeMode = false

function getTime()
	return os.date("%H:%M:%S")
end
function getWorldName()
	local world = GetWorld()
	if world and world.name then
		return world.name
	end
	return "UNKNOWN"
end
function addLog(text)
	local time = getTime()
	local world = getWorldName()
	local final = "`7["..time.."] `9("..world..") "..text
	table.insert(logs, 1, final)
	if #logs > 15 then
		table.remove(logs)
	end
end
function addSpinLog(text)
	local time = getTime()
	local world = getWorldName()
	local final = "`7["..time.."] `9("..world..") "..text
	table.insert(spinLogs, 1, final)
	if #spinLogs > 15 then
		table.remove(spinLogs)
	end
end
function addChatLog(name, msg)
	local time = getTime()
	local world = getWorldName()
	local final = "`7["..time.."] `9("..world..") `w"..name.."`7: `f"..msg
	table.insert(chatLogs, 1, final)
	if #chatLogs > 30 then
		table.remove(chatLogs)
	end
end

-- ================= DROP FUNCTION =================
function drop_bgl(amount)
	SendPacket(2, [[action|dialog_return
dialog_name|drop_item
itemID|7188|
count|]] .. amount .. [[
]])
	addLog("`w"..GetLocal().name.." `cDropped `9"..amount.." BGL")
end
function drop_dl(amount)
	SendPacket(2, [[action|dialog_return
dialog_name|drop_item
itemID|1796|
count|]] .. amount .. [[
]])
	addLog("`w"..GetLocal().name.." `cDropped `9"..amount.." DL")
end

-- ================= TALK BUBBLE =================
function talkBubble(text)
	local localPlayer = GetLocal()
	if not localPlayer then return end
	SendVariantList({
		[0] = "OnTalkBubble",
		[1] = localPlayer.netid,
		[2] = text
	})
end

